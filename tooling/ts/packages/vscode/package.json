{
  "name": "suluk-vscode",
  "displayName": "Suluk — OpenAPI v4 (Candidate)",
  "description": "The unifying cockpit for the Suluk declarative cycle: validate, audit, preview (Scalar/Swagger), and generate stores/UI from one v4 source. CANDIDATE tooling — not official OAS.",
  "version": "0.1.0",
  "publisher": "MahmoodKhalil",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/MahmoodKhalil57/suluk" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:yaml", "onLanguage:json"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "suluk", "title": "Suluk", "icon": "$(symbol-namespace)" }
      ]
    },
    "views": {
      "suluk": [
        { "id": "suluk.cycle", "name": "Cycle", "contextualTitle": "Suluk Cycle" },
        { "id": "suluk.builder", "name": "Builder", "contextualTitle": "Suluk Builder" }
      ]
    },
    "commands": [
      { "command": "suluk.validate", "title": "Suluk: Validate v4 document" },
      { "command": "suluk.audit", "title": "Suluk: Audit documentation coverage" },
      { "command": "suluk.previewScalar", "title": "Suluk: Preview in Scalar" },
      { "command": "suluk.previewSwagger", "title": "Suluk: Preview in Swagger UI" },
      { "command": "suluk.refreshCycle", "title": "Suluk: Refresh Cycle", "icon": "$(refresh)" },
      { "command": "suluk.viewAs", "title": "Suluk: View as (principal scopes)…", "icon": "$(account)" },
      { "command": "suluk.generateForm", "title": "Suluk: Generate shadcn form for entity…" },
      { "command": "suluk.generateTable", "title": "Suluk: Generate shadcn table for entity…" },
      { "command": "suluk.generateStores", "title": "Suluk: Generate Nano Stores client" },
      { "command": "suluk.exportV4", "title": "Suluk: Export v4 document (JSON)" },
      { "command": "suluk.runChecks", "title": "Suluk: Run contract checks" },
      { "command": "suluk.generateApp", "title": "Suluk: Generate full app (backend + frontend)" },
      { "command": "suluk.exportRegistry", "title": "Suluk: Export shadcn registry (whole-stack)" },
      { "command": "suluk.refreshBuilder", "title": "Suluk: Refresh Builder", "icon": "$(refresh)" },
      { "command": "suluk.deployCloudflare", "title": "Suluk: Deploy to Cloudflare (Workers + D1 + assets)", "icon": "$(cloud-upload)" }
    ],
    "menus": {
      "view/title": [
        { "command": "suluk.refreshCycle", "when": "view == suluk.cycle", "group": "navigation" },
        { "command": "suluk.viewAs", "when": "view == suluk.cycle", "group": "navigation" },
        { "command": "suluk.refreshBuilder", "when": "view == suluk.builder", "group": "navigation" },
        { "command": "suluk.generateApp", "when": "view == suluk.builder", "group": "navigation" },
        { "command": "suluk.deployCloudflare", "when": "view == suluk.builder", "group": "navigation" }
      ]
    }
  },
  "dependencies": {
    "@suluk/core": "workspace:*",
    "@suluk/cockpit": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "^1.85.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p .",
    "build": "bun build ./src/extension.ts --outdir dist --target node --external vscode --format cjs"
  }
}
