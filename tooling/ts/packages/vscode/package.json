{
  "name": "suluk-vscode",
  "displayName": "Suluk \u2014 OpenAPI v4 (Candidate)",
  "description": "The unifying cockpit for the Suluk declarative cycle: validate, audit, preview (Scalar/Swagger), and generate stores/UI from one v4 source. CANDIDATE tooling \u2014 not official OAS.",
  "version": "0.1.15",
  "publisher": "MahmoodKhalil",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0c0e1f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MahmoodKhalil57/suluk"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "suluk",
          "title": "Suluk",
          "icon": "media/suluk-activitybar.svg"
        }
      ]
    },
    "views": {
      "suluk": [
        {
          "id": "suluk.cycle",
          "name": "Cycle",
          "contextualTitle": "Suluk Cycle"
        },
        {
          "id": "suluk.builder",
          "name": "Builder",
          "contextualTitle": "Suluk Builder"
        },
        {
          "id": "suluk.environments",
          "name": "Environments",
          "contextualTitle": "Suluk Environments"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "suluk.cycle",
        "contents": "Welcome to the **Suluk cockpit**.\n\nIt shows every layer of an API \u2014 data, contract, auth, docs, state, UI, cost, tests \u2014 all derived from one OpenAPI v4 document.\n\nNothing is loaded yet. Light it up:\n[\u25b6  Open a sample API](command:suluk.openSample)\n[\ud83c\udf10  Load from a URL\u2026](command:suluk.openFromUrl)\n\nAlready have a contract? Open a `.yaml`/`.json` file whose `openapi:` starts with `4`.\n\n[\ud83d\udcd6  Read the docs](https://mahmoodkhalil57.github.io/suluk/)"
      },
      {
        "view": "suluk.builder",
        "contents": "The **Builder** composes a full stack from your entities \u2014 pages \u2192 sections \u2192 blocks \u2192 components \u2014 and generates the app + a shadcn registry.\n\nLoad a v4 document first:\n[\u25b6  Open a sample API](command:suluk.openSample)\n[\ud83c\udf10  Load from a URL\u2026](command:suluk.openFromUrl)\n\nThen use **Generate full app** from the view toolbar."
      }
    ],
    "commands": [
      {
        "command": "suluk.openSample",
        "title": "Suluk: Open a sample API"
      },
      {
        "command": "suluk.agents",
        "title": "Suluk: Agents (x-suluk-agents observe view + model selection)"
      },
      {
        "command": "suluk.openFromUrl",
        "title": "Suluk: Load a v4 document from a URL\u2026"
      },
      {
        "command": "suluk.validate",
        "title": "Suluk: Validate v4 document"
      },
      {
        "command": "suluk.audit",
        "title": "Suluk: Audit documentation coverage"
      },
      {
        "command": "suluk.previewScalar",
        "title": "Suluk: Preview in Scalar"
      },
      {
        "command": "suluk.previewSwagger",
        "title": "Suluk: Preview in Swagger UI"
      },
      {
        "command": "suluk.refreshCycle",
        "title": "Suluk: Refresh Cycle",
        "icon": "$(refresh)"
      },
      {
        "command": "suluk.viewAs",
        "title": "Suluk: View as (principal scopes)\u2026",
        "icon": "$(account)"
      },
      {
        "command": "suluk.compareViewers",
        "title": "Suluk: Compare viewers (View-as cross-cut)",
        "icon": "$(table)"
      },
      {
        "command": "suluk.generateForm",
        "title": "Suluk: Generate shadcn form for entity\u2026"
      },
      {
        "command": "suluk.generateTable",
        "title": "Suluk: Generate shadcn table for entity\u2026"
      },
      {
        "command": "suluk.generateStores",
        "title": "Suluk: Generate Nano Stores client"
      },
      {
        "command": "suluk.exportV4",
        "title": "Suluk: Export v4 document (JSON)"
      },
      {
        "command": "suluk.runChecks",
        "title": "Suluk: Run contract checks"
      },
      {
        "command": "suluk.shipChecklist",
        "title": "Suluk: Ship readiness (the round-trip checklist)",
        "icon": "$(rocket)"
      },
      {
        "command": "suluk.convergeContract",
        "title": "Suluk: Converge (coherence audit of the whole contract)",
        "icon": "$(check-all)"
      },
      {
        "command": "suluk.previewComponents",
        "title": "Suluk: Component preview + pixel-confidence (verify once)",
        "icon": "$(symbol-color)"
      },
      {
        "command": "suluk.generateDiagram",
        "title": "Suluk: Generate a diagram (D2 — ERD / cycle / operations)",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "suluk.generateApp",
        "title": "Suluk: Generate full app (backend + frontend)"
      },
      {
        "command": "suluk.exportRegistry",
        "title": "Suluk: Export shadcn registry (whole-stack)"
      },
      {
        "command": "suluk.composePlatform",
        "title": "Suluk: Compose a platform (stack template → working contract)",
        "icon": "$(layers)"
      },
      {
        "command": "suluk.installModule",
        "title": "Suluk: Browse modules (first-party or remote registry)",
        "icon": "$(package)"
      },
      {
        "command": "suluk.addRegistry",
        "title": "Suluk: Add a module registry (remote URL)",
        "icon": "$(globe)"
      },
      {
        "command": "suluk.signRegistry",
        "title": "Suluk: Sign this registry (publisher — emit a signed envelope + keypair)",
        "icon": "$(key)"
      },
      {
        "command": "suluk.swapProvider",
        "title": "Suluk: Swap a provider (payments/auth/email/storage)",
        "icon": "$(plug)"
      },
      {
        "command": "suluk.refreshBuilder",
        "title": "Suluk: Refresh Builder",
        "icon": "$(refresh)"
      },
      {
        "command": "suluk.deployCloudflare",
        "title": "Suluk: Deploy to Cloudflare (Workers + D1 + assets)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "suluk.refreshEnvironments",
        "title": "Suluk: Refresh environments (health)",
        "icon": "$(refresh)"
      },
      {
        "command": "suluk.addEnvironment",
        "title": "Suluk: Add an environment…",
        "icon": "$(add)"
      },
      {
        "command": "suluk.removeEnvironment",
        "title": "Suluk: Remove this environment",
        "icon": "$(trash)"
      },
      {
        "command": "suluk.connectEnvironment",
        "title": "Suluk: Connect (load the live contract)",
        "icon": "$(plug)"
      },
      {
        "command": "suluk.diffEnvironment",
        "title": "Suluk: Diff local contract against this environment",
        "icon": "$(git-compare)"
      },
      {
        "command": "suluk.openCostLedger",
        "title": "Suluk: Open the live cost ledger",
        "icon": "$(graph)"
      },
      {
        "command": "suluk.openLiveApp",
        "title": "Suluk: Open the live app in a browser",
        "icon": "$(globe)"
      },
      {
        "command": "suluk.openSuperadmin",
        "title": "Suluk: Open the superadmin panel in a browser",
        "icon": "$(shield)"
      },
      {
        "command": "suluk.openScalarLive",
        "title": "Suluk: Open the live Scalar docs in a browser",
        "icon": "$(book)"
      },
      {
        "command": "suluk.previewAsRole",
        "title": "Suluk: Preview as role (open the running app as a principal)…",
        "icon": "$(person)"
      },
      {
        "command": "suluk.deployPreview",
        "title": "Suluk: Deploy a preview (role-preview) to Cloudflare",
        "icon": "$(beaker)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "suluk.refreshCycle",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.viewAs",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.compareViewers",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.shipChecklist",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.convergeContract",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.previewComponents",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.generateDiagram",
          "when": "view == suluk.cycle",
          "group": "navigation"
        },
        {
          "command": "suluk.refreshBuilder",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.generateApp",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.composePlatform",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.installModule",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.deployCloudflare",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.deployPreview",
          "when": "view == suluk.builder",
          "group": "navigation"
        },
        {
          "command": "suluk.addEnvironment",
          "when": "view == suluk.environments",
          "group": "navigation"
        },
        {
          "command": "suluk.refreshEnvironments",
          "when": "view == suluk.environments",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        { "command": "suluk.connectEnvironment", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "inline@1" },
        { "command": "suluk.diffEnvironment", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "inline@2" },
        { "command": "suluk.openCostLedger", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "inline@3" },
        { "command": "suluk.diffEnvironment", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "1_observe@1" },
        { "command": "suluk.openCostLedger", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "1_observe@2" },
        { "command": "suluk.previewAsRole", "when": "view == suluk.environments && viewItem == suluk.env.preview", "group": "2_open@0" },
        { "command": "suluk.openLiveApp", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "2_open@1" },
        { "command": "suluk.openScalarLive", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "2_open@2" },
        { "command": "suluk.openSuperadmin", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "2_open@3" },
        { "command": "suluk.removeEnvironment", "when": "view == suluk.environments && viewItem =~ /^suluk.env/", "group": "9_danger@1" }
      ]
    }
  },
  "dependencies": {
    "@suluk/core": "workspace:*",
    "@suluk/cockpit": "workspace:*",
    "@suluk/models": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "^1.85.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p .",
    "build": "bun build ./src/extension.ts --outdir dist --target node --external vscode --format cjs"
  }
}