{
  "name": "@suluk/example-petshop",
  "version": "0.1.1",
  "private": true,
  "description": "End-to-end demo: Drizzle tables \u2192 @suluk/builder \u2192 a live validated CRUD server + Scalar docs + generated frontend, all from one source. CANDIDATE tooling.",
  "type": "module",
  "main": "src/app.ts",
  "dependencies": {
    "@suluk/builder": "workspace:*",
    "@suluk/drizzle": "workspace:*",
    "@suluk/core": "workspace:*",
    "@suluk/hono": "workspace:*",
    "@suluk/scalar": "workspace:*",
    "@suluk/admin": "workspace:*",
    "@suluk/cost": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@suluk/openapi-compat": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.0.0",
    "@hono/zod-validator": "^0.8.0",
    "zod": "^4.4.3",
    "@suluk/nano-stores": "workspace:*",
    "nanostores": "^1.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "@hookform/resolvers": "^3.9.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "scripts": {
    "start": "bun src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p .",
    "gen:frontend": "bun scripts/generate-frontend.ts",
    "build:frontend": "bun build ./frontend/index.html --outdir dist/client --minify"
  }
}